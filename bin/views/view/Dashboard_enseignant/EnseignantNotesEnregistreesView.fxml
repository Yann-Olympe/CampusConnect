<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Controllers_enseignant.EnseignantNotesEnregistreesController"
      spacing="20.0"
      styleClass="content-root"
      stylesheets="@../../css/dashboard_enseignant.css">

    <children>
        <Label text="Notes enregistrées" styleClass="page-title"/>

        <HBox spacing="10.0">
            <children>
                <ComboBox promptText="Cours" styleClass="custom-combo" prefWidth="220.0"/>
                <ComboBox promptText="Groupe" styleClass="custom-combo" prefWidth="180.0"/>
                <ComboBox promptText="Type d’évaluation" styleClass="custom-combo" prefWidth="220.0"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Exporter" styleClass="secondary-btn"/>
            </children>
        </HBox>

        <VBox spacing="12.0" styleClass="card" VBox.vgrow="ALWAYS">
            <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
            <children>
                <Label text="Historique des évaluations" styleClass="section-title"/>
                <TableView fx:id="notesTable" VBox.vgrow="ALWAYS" styleClass="custom-table">
                    <columns>
                        <TableColumn fx:id="colCours" text="Cours" prefWidth="180.0"/>
                        <TableColumn fx:id="colGroupe" text="Groupe" prefWidth="100.0"/>
                        <TableColumn fx:id="colEvaluation" text="Type d’évaluation" prefWidth="190.0"/>
                        <TableColumn fx:id="colCoefficient" text="Coefficient" prefWidth="110.0"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="120.0"/>
                        <TableColumn fx:id="colEtudiantsEvalues" text="Étudiants évalués" prefWidth="150.0"/>
                        <TableColumn fx:id="colMoyenne" text="Moyenne" prefWidth="120.0"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="120.0"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>