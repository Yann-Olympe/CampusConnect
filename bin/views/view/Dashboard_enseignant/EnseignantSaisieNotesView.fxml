<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Controllers_enseignant.EnseignantSaisieNotesController"
      spacing="20.0"
      styleClass="content-root"
      stylesheets="@../../css/dashboard_enseignant.css">

    <Label text="Saisie des notes" styleClass="page-title"/>
    <HBox spacing="10.0">
        <ComboBox fx:id="groupeCombo" promptText="Sélectionner un groupe" prefWidth="250"/>
        <ComboBox fx:id="evaluationCombo" promptText="Type d'évaluation" prefWidth="200"/>
        <Button text="Charger les étudiants" onAction="#chargerEtudiants" styleClass="primary-button"/>
    </HBox>
    <VBox spacing="12.0" styleClass="card" VBox.vgrow="ALWAYS">
        <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
        <TableView fx:id="etudiantsTable" VBox.vgrow="ALWAYS" styleClass="custom-table">
            <columns>
                <TableColumn fx:id="colMatricule" text="Matricule" prefWidth="100"/>
                <TableColumn fx:id="colNom" text="Nom" prefWidth="120"/>
                <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="120"/>
                <TableColumn fx:id="colNote" text="Note" prefWidth="100"/>
                <TableColumn fx:id="colAction" text="Action" prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>
    <HBox alignment="CENTER_RIGHT">
        <Label fx:id="statusLabel" styleClass="status-label"/>
    </HBox>
</VBox>