<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Controllers_enseignant.EnseignantGroupesController"
      spacing="20.0"
      styleClass="content-root"
      stylesheets="@../../css/dashboard_enseignant.css">

    <children>
        <Label text="Mes groupes" styleClass="page-title"/>

        <HBox spacing="10.0">
            <children>
                <TextField fx:id="searchField" promptText="Rechercher un groupe..." styleClass="custom-input" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="coursFilter" promptText="Tous les cours" styleClass="custom-combo" prefWidth="220.0"/>
                <Button text="Actualiser" styleClass="secondary-btn"/>
            </children>
        </HBox>

        <VBox spacing="12.0" styleClass="card" VBox.vgrow="ALWAYS">
            <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
            <children>
                <Label text="Liste des groupes affectés" styleClass="section-title"/>
                <TableView fx:id="groupesTable" VBox.vgrow="ALWAYS" styleClass="custom-table">
                    <columns>
                        <TableColumn fx:id="colCours" text="Cours" prefWidth="220.0"/>
                        <TableColumn fx:id="colGroupe" text="Groupe" prefWidth="100.0"/>
                        <TableColumn fx:id="colType" text="Type" prefWidth="100.0"/>
                        <TableColumn fx:id="colCapacite" text="Capacité" prefWidth="100.0"/>
                        <TableColumn fx:id="colInscrits" text="Inscrits" prefWidth="100.0"/>
                        <TableColumn fx:id="colSalle" text="Salle" prefWidth="180.0"/>
                        <TableColumn fx:id="colStatut" text="Statut" prefWidth="100.0"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="140.0"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>