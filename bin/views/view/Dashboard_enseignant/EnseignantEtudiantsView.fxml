<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Controllers_enseignant.EnseignantEtudiantsController"
      spacing="20.0"
      styleClass="content-root"
      stylesheets="@../../css/dashboard_enseignant.css">

    <children>
        <Label text="Étudiants de mes groupes" styleClass="page-title"/>

        <HBox spacing="10.0">
            <children>
                <ComboBox promptText="Choisir un cours" styleClass="custom-combo" prefWidth="260.0"/>
                <ComboBox promptText="Choisir un groupe" styleClass="custom-combo" prefWidth="220.0"/>
                <TextField promptText="Rechercher un étudiant..." styleClass="custom-input" HBox.hgrow="ALWAYS"/>
                <Button text="Exporter" styleClass="secondary-btn"/>
            </children>
        </HBox>

        <VBox spacing="12.0" styleClass="card" VBox.vgrow="ALWAYS">
            <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
            <children>
                <Label text="Liste des étudiants inscrits" styleClass="section-title"/>
                <TableView fx:id="etudiantsTable" VBox.vgrow="ALWAYS" styleClass="custom-table">
                    <columns>
                        <TableColumn fx:id="colMatricule" text="Matricule" prefWidth="150.0"/>
                        <TableColumn fx:id="colNom" text="Nom" prefWidth="150.0"/>
                        <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="150.0"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="260.0"/>
                        <TableColumn fx:id="colAnnee" text="Année" prefWidth="90.0"/>
                        <TableColumn fx:id="colMoyenne" text="Moyenne actuelle" prefWidth="160.0"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>