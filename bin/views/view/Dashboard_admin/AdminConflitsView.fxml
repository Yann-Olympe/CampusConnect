<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Controllers_admin.AdminConflitsController"
      spacing="18.0"
      styleClass="content-root"
      stylesheets="@../../css/dashboard_admin.css">

    <children>
        <Label text="Gestion des conflits horaires" styleClass="page-title"/>

        <HBox spacing="10.0">
            <children>
                <Button text="Analyser les conflits" styleClass="primary-btn" onAction="#handleAnalyser"/>
                <Button text="Actualiser" styleClass="secondary-btn" onAction="#handleRefresh"/>
            </children>
        </HBox>

        <VBox styleClass="card" VBox.vgrow="ALWAYS">
            <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
            <children>
                <TableView fx:id="conflitsTable" VBox.vgrow="ALWAYS" styleClass="custom-table">
                    <columns>
                        <TableColumn fx:id="colTypeConflit" text="Type de conflit" prefWidth="180.0"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="120.0"/>
                        <TableColumn fx:id="colHoraire" text="Horaire" prefWidth="160.0"/>
                        <TableColumn fx:id="colRessource" text="Ressource concernée" prefWidth="220.0"/>
                        <TableColumn fx:id="colSeance1" text="Séance 1" prefWidth="220.0"/>
                        <TableColumn fx:id="colSeance2" text="Séance 2" prefWidth="220.0"/>
                        <TableColumn fx:id="colStatut" text="Statut" prefWidth="120.0"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>