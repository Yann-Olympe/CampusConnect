<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Controllers_admin.AdminGroupesController"
      spacing="18.0"
      styleClass="content-root"
      stylesheets="@../../css/dashboard_admin.css">

    <children>
        <Label text="Gestion des groupes pédagogiques" styleClass="page-title"/>

        <VBox spacing="12.0" styleClass="card">
            <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>
            <children>
                <Label text="Formulaire groupe" styleClass="section-title"/>

                <GridPane hgap="12.0" vgap="12.0">
                    <children>
                        <ComboBox fx:id="coursCombo" promptText="Cours" prefWidth="220.0"/>
                        <TextField fx:id="nomGroupeField" promptText="Nom du groupe" GridPane.columnIndex="1"/>
                        <ComboBox fx:id="typeCombo" promptText="Type (CM/TD/TP)" prefWidth="180.0" GridPane.columnIndex="2"/>
                        <TextField fx:id="capaciteField" promptText="Capacité maximale" GridPane.columnIndex="3"/>

                        <ComboBox fx:id="enseignantCombo" promptText="Enseignant affecté" prefWidth="220.0" GridPane.rowIndex="1"/>
                        <ComboBox fx:id="salleCombo" promptText="Salle par défaut" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    </children>
                </GridPane>

                <HBox spacing="10.0">
                    <children>
                        <Button text="Ajouter" styleClass="primary-btn" onAction="#handleAjouter"/>
                        <Button text="Modifier" styleClass="secondary-btn" onAction="#handleModifier"/>
                        <Button text="Supprimer" styleClass="danger-btn" onAction="#handleSupprimer"/>
                        <Button text="Réinitialiser" styleClass="secondary-btn" onAction="#handleReset"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox styleClass="card" VBox.vgrow="ALWAYS">
            <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
            <children>
                <TableView fx:id="groupesTable" VBox.vgrow="ALWAYS" styleClass="custom-table">
                    <columns>
                        <TableColumn fx:id="colCours" text="Cours" prefWidth="200.0"/>
                        <TableColumn fx:id="colNomGroupe" text="Groupe" prefWidth="120.0"/>
                        <TableColumn fx:id="colType" text="Type" prefWidth="90.0"/>
                        <TableColumn fx:id="colCapacite" text="Capacité" prefWidth="100.0"/>
                        <TableColumn fx:id="colEffectif" text="Effectif" prefWidth="100.0"/>
                        <TableColumn fx:id="colEnseignant" text="Enseignant" prefWidth="180.0"/>
                        <TableColumn fx:id="colSalle" text="Salle" prefWidth="120.0"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>