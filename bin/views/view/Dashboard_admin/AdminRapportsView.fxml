<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="CampusConnect.controllers.Controllers_admin.AdminRapportsController"
      spacing="18.0"
      styleClass="content-root"
      stylesheets="@../../css/dashboard_admin.css">

    <children>
        <Label text="Rapports exportables" styleClass="page-title"/>

        <GridPane hgap="15.0" vgap="15.0">
            <children>
                <VBox styleClass="card">
                    <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>
                    <children>
                        <Label text="Relevés de notes globaux" styleClass="section-title"/>
                        <Button text="Générer PDF" styleClass="primary-btn" onAction="#handleReleves"/>
                    </children>
                </VBox>

                <VBox styleClass="card" GridPane.columnIndex="1">
                    <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>
                    <children>
                        <Label text="Planning général" styleClass="section-title"/>
                        <Button text="Exporter" styleClass="primary-btn" onAction="#handlePlanning"/>
                    </children>
                </VBox>

                <VBox styleClass="card" GridPane.columnIndex="2">
                    <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>
                    <children>
                        <Label text="Liste étudiants par filière" styleClass="section-title"/>
                        <Button text="Exporter" styleClass="primary-btn" onAction="#handleEtudiantsFiliere"/>
                    </children>
                </VBox>

                <VBox styleClass="card" GridPane.columnIndex="3">
                    <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>
                    <children>
                        <Label text="Liste étudiants par groupe" styleClass="section-title"/>
                        <Button text="Exporter" styleClass="primary-btn" onAction="#handleEtudiantsGroupe"/>
                    </children>
                </VBox>
            </children>
        </GridPane>
    </children>
</VBox>