<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 20; -fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.NotificationsController">
    <Label text="Notifications" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
    <HBox spacing="10">
        <Label text="Catégorie :" /><ComboBox fx:id="categorieCombo" promptText="Toutes" />
        <Label text="Date :" /><ComboBox fx:id="dateCombo" promptText="Toutes" />
        <Label text="Statut :" /><ComboBox fx:id="statutCombo" promptText="Tous" />
        <Button text="Filtrer" styleClass="primary-button" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Marquer tout comme lu" styleClass="secondary-button" />
    </HBox>
    <ListView fx:id="notificationsList" VBox.vgrow="ALWAYS" />
</VBox>