<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" stylesheets="@dashboard_views.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.Controllers_etudiant.MesGroupesController">
    <VBox alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="20" left="30" right="30" top="20" />
        </padding>

        <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E63D5;" text="👥 Informations sur mes groupes de cours" />

        <!-- TableView responsive -->
        <TableView fx:id="groupesTable" style="-fx-pref-width: 0; -fx-max-width: Infinity; -fx-min-width: 300;" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colCours" prefWidth="180" text="COURS" />
                <TableColumn fx:id="colType" prefWidth="80" text="TYPE" />
                <TableColumn fx:id="colGroupe" prefWidth="100" text="GROUPE" />
                <TableColumn fx:id="colEnseignant" prefWidth="160" text="ENSEIGNANT" />
                <TableColumn fx:id="colSalle" prefWidth="100" text="SALLE" />
                <TableColumn fx:id="colCreneau" prefWidth="150" text="CRÉNEAU" />
                <TableColumn fx:id="colStatut" prefWidth="100" text="STATUT" />
                <TableColumn fx:id="colAction" prefWidth="120" text="ACTION" />
            </columns>
        </TableView>

        <!-- Ligne de statut -->
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="statusLabel" style="-fx-text-fill: #64748b;" text="4 groupes chargés" />
        </HBox>
    </VBox>
</ScrollPane>
