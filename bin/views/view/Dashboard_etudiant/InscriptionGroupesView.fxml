<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-padding: 20; -fx-background-color: #F5F7FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.Controllers_etudiant.InscriptionGroupesController">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E63D5;" text="📋 Informations sur les inscriptions aux différents groupes de cours" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- Filtres -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 12 15; -fx-background-radius: 12; -fx-border-color: #D7E3F3; -fx-border-radius: 12;">
        <Label style="-fx-font-weight: bold;" text="🔍 Filtrer par :" />
        <ComboBox fx:id="typeGroupeComboBox" prefWidth="140" promptText="Type de groupe" style="-fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-radius: 6px; -fx-cursor: hand;" />
        <ComboBox fx:id="statutComboBox" prefWidth="140" promptText="Statut" style="-fx-cursor: hand; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#resetFilters" style="-fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-radius: 6px; -fx-cursor: hand;" styleClass="secondary-button" text="⟳ Réinitialiser" />
    </HBox>

    <!-- Tableau des groupes (sans colonne Créneau) -->
    <TableView fx:id="groupesTableView" styleClass="table-view" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCours" prefWidth="180" text="Cours" />
            <TableColumn fx:id="colType" prefWidth="80" text="Type" />
            <TableColumn fx:id="colGroupe" prefWidth="90" text="Groupe" />
            <TableColumn fx:id="colEnseignant" prefWidth="160" text="Enseignant" />
            <TableColumn fx:id="colPlaces" prefWidth="100" text="Places rest." />
            <TableColumn fx:id="colStatut" prefWidth="100" text="Statut" />
            <TableColumn fx:id="colAction" prefWidth="100" text="Action" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <placeholder>
            <Label style="-fx-text-fill: #5F6F8E;" text="Aucun groupe ne correspond aux filtres" />
        </placeholder>
    </TableView>

    <!-- Détails du groupe sélectionné (sans Créneau) -->
    <VBox spacing="12" styleClass="detail-card">
        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E63D5;" text="📌 Détails du groupe sélectionné" />
        <GridPane hgap="15" vgap="8">
            <Label style="-fx-font-weight: bold;" text="Cours :" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="detailCours" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Label style="-fx-font-weight: bold;" text="Type :" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <Label fx:id="detailType" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label style="-fx-font-weight: bold;" text="Groupe :" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <Label fx:id="detailGroupe" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label style="-fx-font-weight: bold;" text="Enseignant :" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <Label fx:id="detailEnseignant" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Label style="-fx-font-weight: bold;" text="Places restantes :" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <Label fx:id="detailPlaces" text="-" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            <Label style="-fx-font-weight: bold;" text="Salle :" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <Label fx:id="detailSalle" text="-" GridPane.columnIndex="1" GridPane.rowIndex="5" />
         <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
         </columnConstraints>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>
    </VBox>

    <HBox alignment="CENTER_RIGHT">
        <Label fx:id="statusLabel" style="-fx-text-fill: #5F6F8E; -fx-font-size: 12px;" />
    </HBox>
</VBox>
