<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox spacing="20" style="-fx-padding: 20; -fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PlanningController">
    <ListView fx:id="joursListe" prefWidth="200" styleClass="card" />
    <VBox spacing="15" HBox.hgrow="ALWAYS">
        <VBox spacing="10" styleClass="card">
            <Label text="Détails de la séance" styleClass="section-title" />
            <Label fx:id="detailCours" text="-" />
            <Label fx:id="detailType" text="-" />
            <Label fx:id="detailGroupe" text="-" />
            <Label fx:id="detailEnseignant" text="-" />
            <Label fx:id="detailSalle" text="-" />
            <Label fx:id="detailDate" text="-" />
            <Label fx:id="detailHeure" text="-" />
            <Label fx:id="detailStatut" text="-" />
            <Button text="Ajouter un rappel" styleClass="primary-button" />
        </VBox>
        <VBox spacing="10" styleClass="card">
            <Label text="Légende des statuts" styleClass="section-title" />
            <FlowPane hgap="15" vgap="5">
                <Label text="● Planifiée" style="-fx-text-fill: #3b82f6;" />
                <Label text="● Confirmée" style="-fx-text-fill: #10b981;" />
                <Label text="● En cours" style="-fx-text-fill: #f59e0b;" />
                <Label text="● Terminée" style="-fx-text-fill: #64748b;" />
                <Label text="● Annulée" style="-fx-text-fill: #ef4444;" />
                <Label text="● Reportée" style="-fx-text-fill: #8b5cf6;" />
            </FlowPane>
        </VBox>
    </VBox>
</HBox>