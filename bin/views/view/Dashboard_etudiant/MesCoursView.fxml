<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" stylesheets="@dashboard_views.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MesCoursController">
    <VBox alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="20" left="30" right="30" top="20" />
        </padding>

        <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="📚 Mes cours" />

        <!-- TableView responsive : prend toute la largeur disponible -->
        <TableView fx:id="coursTable" style="-fx-pref-width: 0; -fx-max-width: Infinity; -fx-min-width: 300;" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colCode" text="CODE" />
                <TableColumn fx:id="colIntitule" text="INTITULÉ" />
                <TableColumn fx:id="colDescription" text="DESCRIPTION" />
                <TableColumn fx:id="colHeures" text="HEURES" />
            <TableColumn prefWidth="75.0" text="ENSEIGNANT" />
            </columns>
        </TableView>

        <!-- Ligne de statut facultative -->
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="statusLabel" style="-fx-text-fill: #64748b;" text="6 cours chargés" />
        </HBox>
    </VBox>
</ScrollPane>
