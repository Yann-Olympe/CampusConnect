<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="content-root" stylesheets="@../../css/dashboard_enseignant.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <children>
        <!-- KPI -->
        <HBox spacing="15.0">
            <VBox prefWidth="220.0" spacing="8.0" styleClass="kpi-card">
                <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                <Label fx:id="nbCoursLabel" styleClass="kpi-label" text="Cours dispensés" />
                <Label fx:id="nbGroupesLabel" styleClass="kpi-value" text="6" />
            </VBox>
            <VBox prefWidth="220.0" spacing="8.0" styleClass="kpi-card">
                <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                <Label fx:id="nbEtudiantsLabel" styleClass="kpi-label" text="Groupes affectés" />
                <Label fx:id="nbNotesAttenteLabel" styleClass="kpi-value" text="8" />
            </VBox>
            <VBox prefWidth="220.0" spacing="8.0" styleClass="kpi-card">
                <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                <Label styleClass="kpi-label" text="Étudiants suivis" />
                <Label styleClass="kpi-value" text="186" />
            </VBox>
            <VBox prefWidth="220.0" spacing="8.0" styleClass="kpi-card-warning">
                <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                <Label styleClass="kpi-label" text="Notes à saisir" />
                <Label styleClass="kpi-value-warning" text="23" />
            </VBox>
        </HBox>

        <!-- MAIN CONTENT -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <!-- LEFT -->
                <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                    <children>
                        <VBox spacing="12.0" styleClass="card" VBox.vgrow="ALWAYS">
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <Label styleClass="section-title" text="Prochaines séances (aujourd’hui)" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button styleClass="link-btn" text="Voir tout" />
                                </HBox>
                                <TableView fx:id="seancesTable" styleClass="custom-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colHeure" prefWidth="120.0" text="Heure" />
                                        <TableColumn fx:id= "colCours" prefWidth="280.0" text="Cours" />
                                        <TableColumn fx:id= "colGroupe" prefWidth="120.0" text="Groupe" />
                                        <TableColumn fx:id= "colSalle" prefWidth="140.0" text="Salle" />
                                    </columns>
                                    <items>
                                        <!-- Vous pouvez peupler avec des données ici ou via contrôleur -->
                                    </items>
                                </TableView>
                            </children>
                        </VBox>
                        <VBox spacing="10.0" styleClass="card">
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                        </VBox>
                    </children>
                </VBox>

                <!-- RIGHT -->
                <VBox prefWidth="380.0" spacing="20.0">
                    <children>
                        <VBox spacing="10.0" styleClass="card">
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                            <Label styleClass="section-title" text="Notifications récentes" />
                            <Label styleClass="list-item" text="• Nouvelle séance ajoutée pour INFO-301 (TD2)" />
                            <Label styleClass="list-item" text="• Salle modifiée pour INFO-302 (TP2)" />
                            <Label styleClass="list-item-warning" text="• 23 notes en attente de saisie" />
                            <Label styleClass="list-item" text="• Évaluation CC2 de INFO-301 à clôturer" />
                        </VBox>
                        <VBox spacing="10.0" styleClass="card">
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                            <Label styleClass="section-title" text="Actions rapides" />
                            <Button maxWidth="Infinity" styleClass="primary-btn" text="Voir mes cours" />
                            <Button maxWidth="Infinity" styleClass="primary-btn" text="Voir mes groupes" />
                            <Button maxWidth="Infinity" styleClass="primary-btn" text="Saisir des notes" />
                            <Button maxWidth="Infinity" styleClass="primary-btn" text="Voir le planning" />
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
