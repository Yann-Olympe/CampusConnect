<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Controllers_admin.AdminPlanningsController"
      spacing="18.0"
      styleClass="content-root"
      stylesheets="@../../css/dashboard_admin.css">

    <children>
        <Label text="Gestion des plannings / séances" styleClass="page-title"/>

        <VBox spacing="12.0" styleClass="card">
            <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>
            <children>
                <Label text="Création d'une séance" styleClass="section-title"/>

                <GridPane hgap="12.0" vgap="12.0">
                    <children>
                        <ComboBox fx:id="coursCombo" promptText="Cours" prefWidth="200.0"/>
                        <ComboBox fx:id="groupeCombo" promptText="Groupe" prefWidth="160.0" GridPane.columnIndex="1"/>
                        <ComboBox fx:id="enseignantCombo" promptText="Enseignant" prefWidth="220.0" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="salleCombo" promptText="Salle" prefWidth="160.0" GridPane.columnIndex="3"/>

                        <DatePicker fx:id="datePicker" promptText="Date" GridPane.rowIndex="1"/>
                        <TextField fx:id="heureDebutField" promptText="Heure début (08:00)" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <TextField fx:id="heureFinField" promptText="Heure fin (10:00)" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <ComboBox fx:id="typeSeanceCombo" promptText="Type séance" prefWidth="160.0" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                    </children>
                </GridPane>

                <HBox spacing="10.0">
                    <children>
                        <Button text="Créer la séance" styleClass="primary-btn" onAction="#handleCreer"/>
                        <Button text="Modifier" styleClass="secondary-btn" onAction="#handleModifier"/>
                        <Button text="Supprimer" styleClass="danger-btn" onAction="#handleSupprimer"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox styleClass="card" VBox.vgrow="ALWAYS">
            <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
            <children>
                <TableView fx:id="planningsTable" VBox.vgrow="ALWAYS" styleClass="custom-table">
                    <columns>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="120.0"/>
                        <TableColumn fx:id="colHoraire" text="Horaire" prefWidth="160.0"/>
                        <TableColumn fx:id="colCours" text="Cours" prefWidth="180.0"/>
                        <TableColumn fx:id="colGroupe" text="Groupe" prefWidth="120.0"/>
                        <TableColumn fx:id="colEnseignant" text="Enseignant" prefWidth="180.0"/>
                        <TableColumn fx:id="colSalle" text="Salle" prefWidth="120.0"/>
                        <TableColumn fx:id="colTypeSeance" text="Type" prefWidth="100.0"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>