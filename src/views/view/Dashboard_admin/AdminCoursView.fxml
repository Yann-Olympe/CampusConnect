<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Controllers_admin.AdminCoursController"
      spacing="18.0"
      styleClass="content-root"
      stylesheets="@../../css/dashboard_admin.css">

    <Label text="Gestion des cours" styleClass="page-title"/>

    <VBox spacing="12.0" styleClass="card">
        <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>
        <Label text="Formulaire cours" styleClass="section-title"/>
        <GridPane hgap="12.0" vgap="12.0">
            <TextField fx:id="codeField" promptText="Code du cours"/>
            <TextField fx:id="intituleField" promptText="Intitulé" GridPane.columnIndex="1"/>
            <TextField fx:id="volumeHoraireField" promptText="Volume horaire" GridPane.columnIndex="2"/>
            <ComboBox fx:id="semestreCombo" promptText="Semestre" prefWidth="160.0" GridPane.columnIndex="3"/>
            <ComboBox fx:id="filiereCombo" promptText="Filière" prefWidth="180.0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="niveauCombo" promptText="Niveau" prefWidth="160.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <ComboBox fx:id="enseignantResponsableCombo" promptText="Enseignant responsable" prefWidth="220.0" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        </GridPane>
        <TextArea fx:id="descriptionArea" promptText="Description du cours..." prefRowCount="3"/>
        <HBox spacing="10.0">
            <Button text="Ajouter" styleClass="primary-btn" onAction="#handleAjouter"/>
            <Button text="Modifier" styleClass="secondary-btn" onAction="#handleModifier"/>
            <Button text="Supprimer" styleClass="danger-btn" onAction="#handleSupprimer"/>
            <Button text="Réinitialiser" styleClass="secondary-btn" onAction="#handleReset"/>
        </HBox>
    </VBox>

    <HBox spacing="10.0">
        <TextField fx:id="searchField" promptText="Rechercher un cours..." HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="filterFiliereCombo" promptText="Toutes les filières" prefWidth="220.0"/>
        <ComboBox fx:id="filterSemestreCombo" promptText="Tous les semestres" prefWidth="180.0"/>
        <Button text="Actualiser" styleClass="secondary-btn" onAction="#handleRefresh"/>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
        <TableView fx:id="coursTable" VBox.vgrow="ALWAYS" styleClass="custom-table">
            <columns>
                <TableColumn fx:id="colCode" text="Code" prefWidth="100.0"/>
                <TableColumn fx:id="colIntitule" text="Intitulé" prefWidth="180.0"/>
                <TableColumn fx:id="colDescription" text="Description" prefWidth="260.0"/>
                <TableColumn fx:id="colVolumeHoraire" text="VH" prefWidth="80.0"/>
                <TableColumn fx:id="colSemestre" text="Semestre" prefWidth="100.0"/>
                <TableColumn fx:id="colFiliere" text="Filière" prefWidth="150.0"/>
                <TableColumn fx:id="colNiveau" text="Niveau" prefWidth="100.0"/>
                <TableColumn fx:id="colResponsable" text="Responsable" prefWidth="180.0"/>
            </columns>
        </TableView>
    </VBox>
</VBox>