<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="CampusConnect.controllers.Controllers_admin.AdminSallesController"
      spacing="18.0"
      styleClass="content-root"
      stylesheets="@../../css/dashboard_admin.css">

    <children>
        <Label text="Gestion des salles" styleClass="page-title"/>

        <VBox spacing="12.0" styleClass="card">
            <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>
            <children>
                <Label text="Formulaire salle" styleClass="section-title"/>

                <GridPane hgap="12.0" vgap="12.0">
                    <children>
                        <TextField fx:id="codeSalleField" promptText="Code salle"/>
                        <TextField fx:id="nomSalleField" promptText="Nom salle" GridPane.columnIndex="1"/>
                        <TextField fx:id="capaciteField" promptText="Capacité" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="typeSalleCombo" promptText="Type" prefWidth="180.0" GridPane.columnIndex="3"/>
                    </children>
                </GridPane>

                <HBox spacing="10.0">
                    <children>
                        <Button text="Ajouter" styleClass="primary-btn" onAction="#handleAjouter"/>
                        <Button text="Modifier" styleClass="secondary-btn" onAction="#handleModifier"/>
                        <Button text="Supprimer" styleClass="danger-btn" onAction="#handleSupprimer"/>
                        <Button text="Réinitialiser" styleClass="secondary-btn" onAction="#handleReset"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox styleClass="card" VBox.vgrow="ALWAYS">
            <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
            <children>
                <TableView fx:id="sallesTable" VBox.vgrow="ALWAYS" styleClass="custom-table">
                    <columns>
                        <TableColumn fx:id="colCodeSalle" text="Code" prefWidth="120.0"/>
                        <TableColumn fx:id="colNomSalle" text="Nom" prefWidth="180.0"/>
                        <TableColumn fx:id="colCapacite" text="Capacité" prefWidth="120.0"/>
                        <TableColumn fx:id="colTypeSalle" text="Type" prefWidth="160.0"/>
                        <TableColumn fx:id="colOccupation" text="Occupation" prefWidth="160.0"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>