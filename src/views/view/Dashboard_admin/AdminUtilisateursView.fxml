<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="CampusConnect.controllers.Controllers_admin.AdminUtilisateursController"
      spacing="18.0"
      styleClass="content-root"
      stylesheets="@../../css/dashboard_admin.css">

    <children>
        <Label text="Gestion des utilisateurs / comptes" styleClass="page-title"/>

        <VBox spacing="12.0" styleClass="card">
            <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>
            <children>
                <Label text="Création / gestion d'un compte" styleClass="section-title"/>

                <GridPane hgap="12.0" vgap="12.0">
                    <children>
                        <TextField fx:id="identifiantField" promptText="Identifiant"/>
                        <PasswordField fx:id="passwordField" promptText="Mot de passe" GridPane.columnIndex="1"/>
                        <ComboBox fx:id="roleCombo" promptText="Rôle" prefWidth="180.0" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="statutCompteCombo" promptText="Statut" prefWidth="180.0" GridPane.columnIndex="3"/>

                        <TextField fx:id="acteurAssocieField" promptText="Acteur associé (matricule/email)" GridPane.rowIndex="1"/>
                    </children>
                </GridPane>

                <HBox spacing="10.0">
                    <children>
                        <Button text="Créer" styleClass="primary-btn" onAction="#handleCreer"/>
                        <Button text="Modifier" styleClass="secondary-btn" onAction="#handleModifier"/>
                        <Button text="Réinitialiser MDP" styleClass="secondary-btn" onAction="#handleResetPassword"/>
                        <Button text="Désactiver" styleClass="danger-btn" onAction="#handleDesactiver"/>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox styleClass="card" VBox.vgrow="ALWAYS">
            <padding><Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/></padding>
            <children>
                <TableView fx:id="utilisateursTable" VBox.vgrow="ALWAYS" styleClass="custom-table">
                    <columns>
                        <TableColumn fx:id="colIdentifiant" text="Identifiant" prefWidth="180.0"/>
                        <TableColumn fx:id="colRole" text="Rôle" prefWidth="120.0"/>
                        <TableColumn fx:id="colActeur" text="Acteur associé" prefWidth="240.0"/>
                        <TableColumn fx:id="colStatut" text="Statut" prefWidth="120.0"/>
                        <TableColumn fx:id="colDerniereConnexion" text="Dernière connexion" prefWidth="180.0"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>