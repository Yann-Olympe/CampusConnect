<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-padding: 20; -fx-background-color: #F5F7FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.Controllers_etudiant.NotesController">

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E63D5;" text="📊 Mes notes" />

    <!-- Filtres -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 12 15; -fx-background-radius: 12; -fx-border-color: #D7E3F3; -fx-border-radius: 12;">
        <Label style="-fx-font-weight: bold;" text="Semestre :" />
        <ComboBox fx:id="semestreCombo" prefWidth="140" style="-fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-radius: 6px; -fx-cursor: hand;" />
        <Label style="-fx-font-weight: bold;" text="Statut :" />
        <ComboBox fx:id="statutCombo" prefWidth="140" style="-fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-radius: 6px; -fx-cursor: hand;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#actualiser" style="-fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-radius: 6px; -fx-cursor: hand;" styleClass="secondary-button" text="⟳ Actualiser" />
    </HBox>

    <!-- Tableau des notes (sans colonne Action) -->
    <TableView fx:id="notesTable" styleClass="table-view" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCode" prefWidth="100" text="CODE" />
            <TableColumn fx:id="colIntitule" prefWidth="250" text="INTITULÉ" />
            <TableColumn fx:id="colCredits" prefWidth="80" text="CRÉDITS" />
            <TableColumn fx:id="colCC" prefWidth="100" text="CC " />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <placeholder>
            <Label style="-fx-text-fill: #5F6F8E;" text="Aucune note disponible" />
        </placeholder>
    </TableView>
</VBox>
