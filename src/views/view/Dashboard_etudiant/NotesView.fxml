<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 20; -fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.NotesController">
    <Label text="Mes notes" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
    <TableView fx:id="notesTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Cours" prefWidth="250" />
            <TableColumn text="Note" prefWidth="100" />
            <TableColumn text="Coef" prefWidth="80" />
            <TableColumn text="Moyenne promo" prefWidth="120" />
        </columns>
    </TableView>
    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Label text="Moyenne générale :" style="-fx-font-weight: bold;" />
        <Label fx:id="moyenneGeneraleLabel" text="14.25" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;" />
        <Label text="/20" />
    </HBox>
</VBox>