<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="920.0" prefWidth="1371.0" stylesheets="@dashboard_etd.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.Controllers_etudiant.DashboardEtudiantController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="71.0" prefWidth="1111.0" spacing="15.0" style="-fx-background-color: #a7c1d41f;" styleClass="top-header">
         <padding>
            <Insets bottom="15.0" left="22.0" right="22.0" top="15.0" />
         </padding>
         <children>
            <Label fx:id="pageTitleLabel" styleClass="page-title" text="Tableau de bord" textFill="WHITE">
               <font>
                  <Font name="Georgia" size="12.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="searchButton" styleClass="icon-button" text="🔍" textFill="RED" />
            <Button fx:id="notificationButton" styleClass="icon-button" text="🔔" />
            <ImageView fitHeight="40.0" fitWidth="40.0" preserveRatio="true" />
            <VBox spacing="2.0">
               <children>
                  <Label fx:id="studentNameLabel" styleClass="user-name" text="Kurain Nagal" />
                  <Label fx:id="studentRoleLabel" styleClass="user-role" text="Étudiant" />
               </children>
            </VBox>
         </children>
      </HBox>
   </top>
   <left>
      <VBox prefWidth="250.0" spacing="10.0" styleClass="sidebar">
         <padding>
            <Insets bottom="20.0" left="16.0" right="16.0" top="20.0" />
         </padding>
         <children>
            <ImageView fitHeight="136.0" fitWidth="182.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../Logos/Applogo.jpg" />
               </image>
            </ImageView>
            <Separator styleClass="sidebar-separator" />
            <VBox alignment="CENTER" spacing="5.0" styleClass="sidebar-profile-card">
               <children>
                  <Label fx:id="sidebarStudentNameLabel" styleClass="sidebar-user-name" text="Kurain Nagal">
                     <font>
                        <Font name="Georgia" size="12.0" />
                     </font>
                  </Label>
                  <Label fx:id="sidebarMatriculeLabel" styleClass="sidebar-user-info" text="Matricule : 21INF1234" />
                  <Label fx:id="sidebarClasseLabel" styleClass="sidebar-user-info" text="Licence 3 - Informatique" textFill="#a7c1d41f">
                     <font>
                        <Font name="Segoe UI" size="12.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            <Separator styleClass="sidebar-separator" />
            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="5.0">
                     <children>
                        <Button fx:id="btnDashboard" maxWidth="Infinity" onAction="#showDashboardView" style="-fx-background-color: #75c9ec30;" styleClass="menu-button active-menu" text="Tableau de bord" textFill="WHITE" />
                        <Button fx:id="btnMesCours" maxWidth="Infinity" onAction="#showMesCoursPlaceholder" styleClass="menu-button" text="Mes cours" />
                        <Button fx:id="btnInscriptionGroupes" maxWidth="Infinity" onAction="#showInscriptionGroupesView" styleClass="menu-button" text="Inscription aux groupes" />
                        <Button fx:id="btnMesGroupes" maxWidth="Infinity" onAction="#showMesGroupesPlaceholder" styleClass="menu-button" text="Mes groupes" />
                        <Button fx:id="btnPlanning" maxWidth="Infinity" onAction="#showPlanningView" styleClass="menu-button" text="Mon planning" />
                        <Button fx:id="btnMesSeances" maxWidth="Infinity" onAction="#showMesSeancesPlaceholder" styleClass="menu-button" text="Mes séances" />
                        <Button fx:id="btnMesNotes" maxWidth="Infinity" onAction="#showMesNotesPlaceholder" styleClass="menu-button" text="Mes notes" />
                        <Button fx:id="btnMonReleve" maxWidth="Infinity" onAction="#showMonRelevePlaceholder" styleClass="menu-button" text="Mon relevé" />
                        <Button fx:id="btnNotifications" maxWidth="Infinity" onAction="#showNotificationsPlaceholder" styleClass="menu-button" text="Notifications" />
                        <Button fx:id="btnMonProfil" maxWidth="Infinity" onAction="#showMonProfilPlaceholder" styleClass="menu-button" text="Mon profil" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
            <Button fx:id="btnLogout" maxWidth="Infinity" onAction="#handleLogout" prefHeight="38.0" prefWidth="154.0" style="-fx-background-color: radial-gradient(focus-angle 0.0deg, focus-distance 0.0% , center 51.3274% 51.1364%, radius 80.2752%, #048bfa 0.0%, #e01919b8 100.0%); -fx-background-radius: 12px; -fx-border-radius: 12px; -fx-font-weight: bold;" styleClass="logout-button" text="  Déconnexion" textAlignment="CENTER" textFill="#ffffffb8" />
         </children>
      </VBox>
   </left>
   <center>
      <StackPane fx:id="contentArea" prefHeight="926.0" prefWidth="1241.0" style="-fx-background-color: #bec8cc;" styleClass="content-container" />
   </center>
</BorderPane>
