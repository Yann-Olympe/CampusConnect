<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-padding: 20; -fx-background-color: #F5F7FB;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.Controllers_etudiant.MesSeancesController">

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E63D5;" text="📅 Mes séances" />

    <!-- Filtres -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 12 15; -fx-background-radius: 12; -fx-border-color: #D7E3F3; -fx-border-radius: 12;">
        <Label style="-fx-font-weight: bold;" text="Du :" />
        <DatePicker fx:id="dateDebutPicker" prefWidth="120" promptText="01/04/2024" style="-fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6px; -fx-border-radius: 6px;" />
        <Label style="-fx-font-weight: bold;" text="Au :" />
        <DatePicker fx:id="dateFinPicker" prefWidth="120" promptText="30/04/2024" style="-fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-radius: 6px;" />
        <Label style="-fx-font-weight: bold;" text="Cours :" />
        <ComboBox fx:id="coursComboBox" prefWidth="150" promptText="Tous" style="-fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-radius: 6px;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#resetFilters" style="-fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6px; -fx-border-radius: 6px;" styleClass="secondary-button" text="⟳ Réinitialiser" />
    </HBox>

    <!-- Tableau des séances -->
    <TableView fx:id="seancesTable" style="-fx-background-radius: 12px; -fx-border-radius: 12px;" styleClass="table-view" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDate" prefWidth="130" text="Date" />
            <TableColumn fx:id="colHeureDebut" prefWidth="100" text="Heure début" />
            <TableColumn fx:id="colHeureFin" prefWidth="100" text="Heure fin" />
            <TableColumn fx:id="colCours" prefWidth="180" text="Cours" />
            <TableColumn fx:id="colType" prefWidth="80" text="Type" />
            <TableColumn fx:id="colGroupe" prefWidth="90" text="Groupe" />
            <TableColumn fx:id="colSalle" prefWidth="90" text="Salle" />
            <TableColumn fx:id="colEnseignant" prefWidth="160" text="Enseignant" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <placeholder>
            <Label style="-fx-text-fill: #5F6F8E;" text="Aucune séance trouvée" />
        </placeholder>
    </TableView>

    <!-- Pagination -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label fx:id="paginationLabel" style="-fx-text-fill: #64748b;" text="Affichage 1 à X sur X séances" />
    </HBox>
</VBox>
