<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 20; -fx-background-color: #F5F7FB;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.Controllers_etudiant.NotificationsController">

    <Label text="🔔 Notifications" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E63D5;" />

    <!-- Filtres -->
    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 12 15; -fx-background-radius: 12; -fx-border-color: #D7E3F3; -fx-border-radius: 12;">
        <Label text="Catégorie :" style="-fx-font-weight: bold;" />
        <ComboBox fx:id="categorieCombo" prefWidth="120" />
        <Label text="Date :" style="-fx-font-weight: bold;" />
        <ComboBox fx:id="dateCombo" prefWidth="120" />
        <Label text="Statut :" style="-fx-font-weight: bold;" />
        <ComboBox fx:id="statutCombo" prefWidth="120" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="⟳ Filtrer" onAction="#filtrer" styleClass="secondary-button" />
        <Button text="✓ Marquer tout comme lu" onAction="#marquerToutLu" styleClass="primary-button" />
    </HBox>

    <!-- Liste des notifications -->
    <ListView fx:id="notificationsList" VBox.vgrow="ALWAYS" styleClass="list-view" />

    <!-- Statut -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label fx:id="statusLabel" style="-fx-text-fill: #64748b;" />
    </HBox>
</VBox>